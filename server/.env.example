# Rede: devnet ou mainnet (free tier da Copa existe nas duas;
# service level 12 = tempo real só na mainnet)
TXLINE_NETWORK=devnet
TXLINE_SERVICE_LEVEL=1
# SOLANA_RPC_URL=https://api.devnet.solana.com
PORT=3001

# --- Authority on-chain (assina criação/resolução de mercados e o bônus) ---
# Uma das duas: o array JSON da secretKey (recomendado em PaaS via secret), ou
# um caminho pra keypair. Sem isso, os endpoints on-chain respondem 503.
# AUTHORITY_KEYPAIR=[12,34,...]
# AUTHORITY_KEYPAIR_PATH=/run/secrets/authority.json

# --- Login social (opcional) ---
# O botão do Google só aparece se o client for buildado com VITE_GOOGLE_CLIENT_ID
# (variável de BUILD do client, definida em client/.env, não aqui).
# Desative o modo convidado (bônus da authority) em produção com ALLOW_GUEST=0.
# ALLOW_GUEST=0

# --- Segurança / hardening HTTP ---
# CORS: lista de origens permitidas (separadas por vírgula). Vazio = aberto (dev).
# Ex.: ALLOWED_ORIGINS=https://chainplay.app,https://www.chainplay.app
ALLOWED_ORIGINS=
# Rate limit global por IP (requisições/minuto). 0 desliga. Padrão 600.
RATE_LIMIT_PER_MIN=600

# --- NFTs de identidade dos jogos ---
# Base pública onde o server é servido (vai dentro do metadata Metaplex das NFTs).
# Ex.: PUBLIC_BASE_URL=https://api.chainplay.app
PUBLIC_BASE_URL=http://localhost:3001
